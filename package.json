{
  "name": "frontieres-api",
  "version": "1.0.0",
  "description": "API des frontières administratives du Sénégal (polygones PostGIS)",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "init-db": "node src/database/init.js",
    "rebuild-localites": "node src/scripts/rebuild-localites.js",
    "fetch-elevation": "node src/scripts/fetch-elevation.js",
    "update-departements": "node src/scripts/update-departements.js",
    "fix-pikine-communes": "node src/scripts/fix-pikine-communes.js",
    "add-attributes": "node src/scripts/add-attributes.js",
    "voronoi-localites": "node src/scripts/voronoi-localites.js",
    "enrich-all": "node src/scripts/update-departements.js && node src/scripts/fix-pikine-communes.js && node src/scripts/add-attributes.js && node src/scripts/voronoi-localites.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2"
  }
}
