                  "id": 1,
                  "name": "Sénégal",
                  "lat": 14.4974,
                  "lon": -14.4524,
                  "elevation": null,
                  "superficie_km2": 196629.32,
                  "population": 22488341,
                  "densite": 114.37,
                  "geometry": { "type": "MultiPolygon", "coordinates": [] }
