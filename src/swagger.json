          "geometry": { "type": "MultiPolygon", "coordinates": [] }
        }
      },
      "Departement": {
        "allOf": [
          { "$ref": "#/components/schemas/BaseProperties" },
          {
            "type": "object",
            "properties": {
              "region_id": { "type": "integer", "description": "ID de la région parente" },
              "code": { "type": "string", "nullable": true, "description": "Code du département" },
              "geometry": { "$ref": "#/components/schemas/GeoJSONGeometry" }
            }
          }
        ],
        "example": {
          "id": 1,
          "name": "Dakar",
          "region_id": 1,
          "code": "DK",
