          "lon": { "type": "number", "nullable": true, "description": "Longitude du centroïde" },
          "elevation": { "type": "number", "nullable": true, "description": "Élévation en mètres (SRTM30m)" },
          "superficie_km2": { "type": "number", "nullable": true, "description": "Superficie en km²" },
          "population": { "type": "integer", "nullable": true, "description": "Population (ANSD 2023)" },
          "densite": { "type": "number", "nullable": true, "description": "Densité en hab/km²" }
        }
      },
      "Pays": {
        "allOf": [
          { "$ref": "#/components/schemas/BaseProperties" },
          {
            "type": "object",
            "properties": {
              "geometry": { "$ref": "#/components/schemas/GeoJSONGeometry" }
            }
          }
        ],
        "example": {
          "id": 1,
          "name": "Sénégal",
          "lat": 14.4974,
          "lon": -14.4524,
          "elevation": null,
          "superficie_km2": 196629.32,
          "population": 22488341,
          "densite": 114.37,
          "geometry": { "type": "MultiPolygon", "coordinates": [] }
        }
      },
