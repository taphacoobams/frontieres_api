  "components": {
    "parameters": {
      "IdPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Identifiant numérique de l'entité"
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "ok", "enum": ["ok", "degraded"] },
          "service": { "type": "string", "example": "frontieres-api" },
          "database": { "type": "string", "example": "connected", "enum": ["connected", "disconnected", "error"] },
          "timestamp": { "type": "string", "format": "date-time", "example": "2025-03-08T12:00:00.000Z" }
        }
      },
      "StatsResponse": {
        "type": "object",
        "properties": {
          "regions": { "type": "integer", "example": 14 },
          "departements": { "type": "integer", "example": 46 },
          "communes": { "type": "integer", "example": 552 },
          "localites": { "type": "integer", "example": 25515 },
          "localites_with_coordinates": { "type": "integer", "example": 25515 },
          "localites_with_population": { "type": "integer", "example": 18000 }
        }
      },
      "GeoJSONGeometry": {
        "type": "object",
        "description": "Géométrie GeoJSON MultiPolygon (SRID 4326)",
        "properties": {
          "type": { "type": "string", "example": "MultiPolygon" },
          "coordinates": { "type": "array", "description": "Coordonnées du polygone [longitude, latitude]" }
        }
      },
      "BaseProperties": {
        "type": "object",
        "description": "Propriétés communes à toutes les entités",
        "properties": {
          "id": { "type": "integer", "description": "Identifiant unique" },
