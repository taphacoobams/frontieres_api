          { "name": "commune_id", "in": "query", "schema": { "type": "integer" }, "description": "Filtrer par ID de commune" },
          { "name": "departement_id", "in": "query", "schema": { "type": "integer" }, "description": "Filtrer par ID de département" },
          { "name": "region_id", "in": "query", "schema": { "type": "integer" }, "description": "Filtrer par ID de région" },
          { "name": "limit", "in": "query", "schema": { "type": "integer" }, "description": "Nombre maximum de features" }
        ],
        "responses": {
          "200": {
            "description": "GeoJSON FeatureCollection",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FeatureCollection" }
              }
            }
          }
        }
      }
    }
